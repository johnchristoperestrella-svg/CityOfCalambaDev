<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Allow real files and directories
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Rewrite all requests to index.php
    # Preserve the request URI and any original query string. The router reads
    # REQUEST_URI directly, so it does not need path data injected as a query.
    RewriteRule ^ index.php [L,QSA]
</IfModule>
